  el.classList.add('active');
  const titles={dashboard:'Genel Bakış',kanban:'Kanban Panosu',timeline:'Zaman Çizelgesi',team:'Ekip Yönetimi',budget:'Bütçe Takibi',risks:'Risk Yönetimi'};
  document.getElementById('page-title').textContent=titles[id]||id;
  if(id==='kanban') renderKanban();
  if(id==='timeline') renderTimeline();
  if(id==='team') renderTeam();
  if(id==='budget') renderBudget();
  if(id==='risks') renderRisks();
}

function openModal(){document.getElementById('modal-overlay').classList.add('open')}
function closeModal(){document.getElementById('modal-overlay').classList.remove('open')}
document.getElementById('modal-overlay').addEventListener('click',function(e){if(e.target===this)closeModal()});

function addTask(){
  const title=document.getElementById('m-title').value.trim();
  if(!title) return;
  const tag=document.getElementById('m-tag').value;
  const owner=document.getElementById('m-owner').value;
  const col=document.getElementById('m-col').value;
  const due=document.getElementById('m-due').value||'—';
  tasks.push({id:Date.now(),title,tag,owner,col,due,start:new Date().toISOString().split('T')[0],end:new Date().toISOString().split('T')[0],progress:0,isCritical:false});
  closeModal();
  document.getElementById('m-title').value='';
  document.getElementById('m-due').value='';
  renderKanban();
  const notif=document.getElementById('notif');
  notif.style.display='block';
  setTimeout(()=>notif.style.display='none',2500);
}

function updateCountdown(){
  const target=new Date('2025-07-01');
  const now=new Date();
  const diff=Math.ceil((target-now)/(1000*60*60*24));
  const el=document.getElementById('countdown-days');
  if(el) el.textContent=diff>0?diff:'Açıldı!';
}

updateCountdown();
renderKanban();
</script>
</body>
</html>
