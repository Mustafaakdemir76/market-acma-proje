<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Market Açma — Proje Yönetimi</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f1117;
  --bg2: #161820;
  --bg3: #1e2030;
  --bg4: #252840;
  --green: #00d68f;
  --green2: #00b87a;
  --green-dim: rgba(0,214,143,0.12);
  --amber: #ffb347;
  --amber-dim: rgba(255,179,71,0.12);
  --red: #ff6b6b;
  --red-dim: rgba(255,107,107,0.12);
  --blue: #5b8dee;
  --blue-dim: rgba(91,141,238,0.12);
  --purple: #b47bff;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #e8eaf2;
  --text2: #9499b7;
  --text3: #5c6080;
  --sidebar: 240px;
  --radius: 12px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.6}
a{text-decoration:none;color:inherit}

::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px}

.app{display:flex;height:100vh;overflow:hidden}

.sidebar{width:var(--sidebar);background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
.logo-area{padding:24px 20px 20px;border-bottom:1px solid var(--border)}
.logo{display:flex;align-items:center;gap:10px}
.logo-icon{width:36px;height:36px;background:var(--green);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.logo-text{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--text);line-height:1.2}
.logo-sub{font-size:11px;color:var(--text3);font-weight:400}
.nav{padding:16px 12px;flex:1}
.nav-label{font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;padding:0 8px;margin-bottom:6px;margin-top:16px}
.nav-label:first-child{margin-top:0}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;cursor:pointer;color:var(--text2);font-size:13px;font-weight:400;transition:all .15s;position:relative;white-space:nowrap}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:var(--green-dim);color:var(--green);font-weight:500}
.nav-item.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:20px;background:var(--green);border-radius:0 3px 3px 0}
.nav-icon{font-size:16px;width:20px;text-align:center;flex-shrink:0}
.nav-badge{margin-left:auto;background:var(--red);color:white;font-size:10px;font-weight:600;padding:1px 6px;border-radius:10px;min-width:18px;text-align:center}
.nav-badge.green{background:var(--green);color:#0f1117}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border)}
.user-card{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;cursor:pointer}
.user-card:hover{background:var(--bg3)}
.avatar{width:32px;height:32px;border-radius:50%;background:var(--green-dim);border:1.5px solid var(--green);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--green);flex-shrink:0}
.user-name{font-size:13px;font-weight:500}
.user-role{font-size:11px;color:var(--text3)}

.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{height:60px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px;flex-shrink:0}
.page-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700}
.topbar-right{display:flex;align-items:center;gap:12px}
.btn{padding:8px 16px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all .15s}
.btn-primary{background:var(--green);color:#0f1117}
.btn-primary:hover{background:var(--green2)}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2)}
.btn-ghost:hover{background:var(--bg3);color:var(--text)}
.content{flex:1;overflow-y:auto;padding:28px}

.view{display:none;animation:fadeIn .2s ease}
.view.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
.stat{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;position:relative;overflow:hidden;transition:border-color .2s}
.stat:hover{border-color:var(--border2)}
.stat-icon{font-size:22px;margin-bottom:12px}
.stat-val{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;line-height:1}
.stat-label{font-size:12px;color:var(--text3);margin-top:4px;font-weight:400}
.stat-sub{font-size:11px;color:var(--text2);margin-top:8px;display:flex;align-items:center;gap:4px}
.stat-glow{position:absolute;top:-20px;right:-20px;width:80px;height:80px;border-radius:50%;opacity:.15;filter:blur(20px)}

.prog-wrap{background:var(--bg4);border-radius:20px;height:6px;overflow:hidden;margin-top:4px}
.prog{height:100%;border-radius:20px;transition:width .8s ease}

.kanban-wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.col{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:16px;min-height:300px}
.col-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.col-title{font-size:12px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--text2)}
.col-count{font-size:11px;background:var(--bg4);color:var(--text2);padding:2px 8px;border-radius:20px}
.task{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;cursor:pointer;transition:all .15s;position:relative}
.task:hover{border-color:var(--border2);transform:translateY(-1px)}
.task-title{font-size:13px;font-weight:500;color:var(--text);line-height:1.4;margin-bottom:8px}
.task-footer{display:flex;align-items:center;justify-content:space-between}
.tag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;letter-spacing:.02em}
.tag-green{background:rgba(0,214,143,.15);color:#00d68f}
.tag-amber{background:rgba(255,179,71,.15);color:#ffb347}
.tag-red{background:rgba(255,107,107,.15);color:#ff6b6b}
.tag-blue{background:rgba(91,141,238,.15);color:#5b8dee}
.tag-purple{background:rgba(180,123,255,.15);color:#b47bff}
.tag-teal{background:rgba(0,200,200,.15);color:#00c8c8}
.av-xs{width:22px;height:22px;border-radius:50%;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;border:1.5px solid var(--bg)}
.av-green{background:rgba(0,214,143,.2);color:var(--green)}
.av-amber{background:rgba(255,179,71,.2);color:var(--amber)}
.av-blue{background:rgba(91,141,238,.2);color:var(--blue)}
.av-purple{background:rgba(180,123,255,.2);color:var(--purple)}
.av-red{background:rgba(255,107,107,.2);color:var(--red)}
.add-task-btn{width:100%;padding:8px;border-radius:8px;background:transparent;border:1px dashed var(--border2);color:var(--text3);font-size:12px;cursor:pointer;margin-top:8px;font-family:'DM Sans',sans-serif;transition:all .15s}
.add-task-btn:hover{background:var(--bg3);color:var(--text2);border-color:var(--border2)}

.table-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
table{width:100%;border-collapse:collapse}
th{padding:12px 16px;text-align:left;font-size:11px;font-weight:600;color:var(--text3);letter-spacing:.05em;text-transform:uppercase;border-bottom:1px solid var(--border);background:var(--bg3)}
td{padding:12px 16px;font-size:13px;border-bottom:1px solid var(--border);color:var(--text)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--bg3)}
.status-pill{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px}
.sp-green{background:var(--green-dim);color:var(--green)}
.sp-amber{background:var(--amber-dim);color:var(--amber)}
.sp-red{background:var(--red-dim);color:var(--red)}
.sp-gray{background:rgba(148,153,183,.1);color:var(--text2)}
.dot{width:6px;height:6px;border-radius:50%;background:currentColor}

.team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.member{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:24px;display:flex;flex-direction:column;align-items:center;text-align:center;transition:border-color .2s}
.member:hover{border-color:var(--border2)}
.av-lg{width:56px;height:56px;border-radius:50%;font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center;margin-bottom:12px;border:2px solid}
.member-name{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:2px}
.member-role{font-size:12px;color:var(--text3);margin-bottom:14px}
.member-stats{display:flex;gap:16px;width:100%}
.mstat{flex:1;background:var(--bg3);border-radius:8px;padding:10px;text-align:center}
.mstat-val{font-family:'Syne',sans-serif;font-size:18px;font-weight:700}
.mstat-label{font-size:10px;color:var(--text3);margin-top:2px}

.budget-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px}
.budget-stat{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.bs-label{font-size:11px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}
.bs-val{font-family:'Syne',sans-serif;font-size:26px;font-weight:800}
.bs-sub{font-size:12px;color:var(--text2);margin-top:4px}
.diff-pos{color:var(--red)}
.diff-neg{color:var(--green)}

.overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1000;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;padding:28px;width:440px;max-width:95vw;animation:modalIn .2s ease}
@keyframes modalIn{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:scale(1)}}
.modal-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:20px}
.field{margin-bottom:16px}
.field label{display:block;font-size:12px;color:var(--text2);margin-bottom:6px;font-weight:500}
.field input,.field select,.field textarea{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:10px 12px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .15s}
.field input:focus,.field select,.field textarea:focus{border-color:var(--green)}
.field select{cursor:pointer}
.field select option{background:var(--bg3)}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:20px}

.section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.section-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700}
.section-sub{font-size:12px;color:var(--text3);margin-top:2px}

.countdown-banner{background:linear-gradient(135deg,rgba(0,214,143,.08),rgba(0,184,122,.04));border:1px solid rgba(0,214,143,.2);border-radius:var(--radius);padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between}
.cd-label{font-size:12px;color:var(--green);font-weight:600;letter-spacing:.05em;text-transform:uppercase;margin-bottom:4px}
.cd-text{font-family:'Syne',sans-serif;font-size:15px;font-weight:700}
.cd-days{font-family:'Syne',sans-serif;font-size:42px;font-weight:800;color:var(--green);line-height:1}
.cd-days-label{font-size:12px;color:var(--text2)}

.overview-grid{display:grid;grid-template-columns:1fr 340px;gap:20px;margin-top:24px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.card-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:16px;color:var(--text)}
.recent-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border)}
.recent-item:last-child{border-bottom:none}
.ri-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.ri-info{flex:1}
.ri-title{font-size:13px;font-weight:500}
.ri-meta{font-size:11px;color:var(--text3);margin-top:1px}
.ri-tag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px}

.risk-list{display:flex;flex-direction:column;gap:12px}
.risk-item{background:var(--bg3);border-radius:8px;padding:14px 16px;border-left:3px solid}
.risk-high{border-left-color:var(--red)}
.risk-mid{border-left-color:var(--amber)}
.risk-low{border-left-color:var(--green)}
.risk-title{font-size:13px;font-weight:600;margin-bottom:4px}
.risk-desc{font-size:12px;color:var(--text2)}
.risk-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;margin-top:8px}
.rb-high{background:var(--red-dim);color:var(--red)}
.rb-mid{background:var(--amber-dim);color:var(--amber)}
.rb-low{background:var(--green-dim);color:var(--green)}

.notif{position:fixed;bottom:24px;right:24px;background:var(--bg2);border:1px solid var(--green);border-radius:10px;padding:14px 18px;font-size:13px;color:var(--green);box-shadow:0 8px 32px rgba(0,0,0,.4);z-index:2000;animation:slideIn .3s ease;display:none}
@keyframes slideIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.gantt-wrapper{position:relative;overflow-x:auto;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding-bottom:20px}
.gantt-grid{min-width:800px;position:relative}
.gantt-header-dates{display:flex;border-bottom:1px solid var(--border);background:var(--bg3);position:sticky;top:0;z-index:10}
.gantt-date{flex:1;text-align:center;font-size:10px;color:var(--text3);padding:8px 0;border-right:1px solid var(--border);min-width:25px}
.gantt-body{position:relative;padding-top:10px}
.gantt-row{display:flex;align-items:center;margin-bottom:8px;position:relative;height:36px}
.gantt-label{width:220px;flex-shrink:0;padding:0 15px;font-size:12px;display:flex;align-items:center;gap:8px;position:sticky;left:0;background:var(--bg2);z-index:5;border-right:1px solid var(--border)}
.gantt-bars-container{flex:1;position:relative;height:100%}
.gantt-bar-wrap{position:absolute;height:24px;top:6px;border-radius:4px;background:var(--bg4);overflow:hidden;display:flex;align-items:center;box-shadow:0 2px 5px rgba(0,0,0,0.2);transition:transform 0.15s}
.gantt-bar-wrap:hover{transform:translateY(-2px)}
.gantt-bar-progress{height:100%;background:var(--blue);position:absolute;left:0;top:0;border-radius:4px;opacity:0.8}
.gantt-bar-text{position:relative;z-index:2;font-size:10px;color:#fff;padding:0 8px;white-space:nowrap;font-weight:600;text-shadow:0 1px 2px rgba(0,0,0,0.5)}
.gantt-critical .gantt-bar-wrap{border:1px solid var(--red)}
.gantt-critical .gantt-bar-progress{background:var(--red);opacity:0.9}
.gantt-today-line{position:absolute;top:0;bottom:0;width:2px;background:var(--amber);z-index:4;pointer-events:none}
.gantt-today-label{position:absolute;top:-20px;left:-15px;background:var(--amber);color:#0f1117;font-size:10px;padding:2px 6px;border-radius:4px;font-weight:700}
</style>
</head>
<body>
<div class="app">

<aside class="sidebar">
  <div class="logo-area">
    <div class="logo">
      <div class="logo-icon">🛒</div>
      <div>
        <div class="logo-text">MarketPro</div>
        <div class="logo-sub">Proje Yönetimi</div>
      </div>
    </div>
  </div>
  <nav class="nav">
    <div class="nav-label">Ana Menü</div>
    <div class="nav-item active" onclick="showView('dashboard',this)">
      <span class="nav-icon">📊</span> Genel Bakış
    </div>
    <div class="nav-item" onclick="showView('kanban',this)">
      <span class="nav-icon">🗂️</span> Kanban Panosu
      <span class="nav-badge">12</span>
    </div>
    <div class="nav-item" onclick="showView('timeline',this)">
      <span class="nav-icon">📅</span> Zaman Çizelgesi
    </div>
    <div class="nav-label">Yönetim</div>
    <div class="nav-item" onclick="showView('team',this)">
      <span class="nav-icon">👥</span> Ekip
    </div>
    <div class="nav-item" onclick="showView('budget',this)">
      <span class="nav-icon">💰</span> Bütçe
      <span class="nav-badge green">₺</span>
    </div>
    <div class="nav-item" onclick="showView('risks',this)">
      <span class="nav-icon">⚠️</span> Riskler
    </div>
  </nav>
  <div class="sidebar-bottom">
    <div class="user-card">
      <div class="avatar">AK</div>
      <div>
        <div class="user-name">Ahmet Kaya</div>
        <div class="user-role">Proje Müdürü</div>
      </div>
    </div>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div class="page-title" id="page-title">Genel Bakış</div>
    <div class="topbar-right">
      <button class="btn btn-ghost" onclick="openModal()">+ Görev Ekle</button>
      <button class="btn btn-primary">📤 Dışa Aktar</button>
    </div>
  </div>

  <div class="content">

    <div class="view active" id="view-dashboard">
      <div class="countdown-banner">
        <div>
          <div class="cd-label">🏪 Açılışa Geri Sayım</div>
          <div class="cd-text">Hedef Açılış: 1 Temmuz 2025, Pazar</div>
        </div>
        <div style="text-align:right">
          <div class="cd-days" id="countdown-days">47</div>
          <div class="cd-days-label">gün kaldı</div>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat">
          <div class="stat-glow" style="background:var(--blue)"></div>
          <div class="stat-icon">📋</div>
          <div class="stat-val" style="color:var(--blue)">16</div>
          <div class="stat-label">Toplam Görev</div>
          <div class="stat-sub">🔵 Aktif projede</div>
        </div>
        <div class="stat">
          <div class="stat-glow" style="background:var(--green)"></div>
          <div class="stat-icon">✅</div>
          <div class="stat-val" style="color:var(--green)" id="dash-done">4</div>
          <div class="stat-label">Tamamlanan</div>
          <div class="stat-sub">🟢 %25 ilerleme</div>
        </div>
        <div class="stat">
          <div class="stat-glow" style="background:var(--amber)"></div>
          <div class="stat-icon">⏳</div>
          <div class="stat-val" style="color:var(--amber)">7</div>
          <div class="stat-label">Devam Ediyor</div>
          <div class="stat-sub">🟡 Aktif çalışma</div>
        </div>
        <div class="stat">
          <div class="stat-glow" style="background:var(--red)"></div>
          <div class="stat-icon">🚨</div>
          <div class="stat-val" style="color:var(--red)">2</div>
          <div class="stat-label">Geciken Görev</div>
          <div class="stat-sub">🔴 Acil takip</div>
        </div>
      </div>

      <div class="overview-grid">
        <div>
          <div class="card-title">📈 Faz İlerlemesi</div>
          <div style="display:flex;flex-direction:column;gap:14px">
            <div>
              <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                <span style="font-size:13px;color:var(--text2)">🏛️ Ruhsat & İzinler</span>
                <span style="font-size:12px;font-weight:600;color:var(--amber)">55%</span>
              </div>
              <div class="prog-wrap"><div class="prog" style="width:55%;background:var(--amber)"></div></div>
            </div>
            <div>
              <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                <span style="font-size:13px;color:var(--text2)">🏗️ Dekorasyon & Teknik</span>
                <span style="font-size:12px;font-weight:600;color:var(--blue)">48%</span>
              </div>
              <div class="prog-wrap"><div class="prog" style="width:48%;background:var(--blue)"></div></div>
            </div>
            <div>
              <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                <span style="font-size:13px;color:var(--text2)">📦 Stok & Tedarik</span>
                <span style="font-size:12px;font-weight:600;color:var(--purple)">35%</span>
              </div>
              <div class="prog-wrap"><div class="prog" style="width:35%;background:var(--purple)"></div></div>
