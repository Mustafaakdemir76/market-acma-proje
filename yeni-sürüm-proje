function renderBudget(){
  let tp=0,ta=0;
  budget.forEach(b=>{tp+=b.planned;ta+=b.actual});
  const rem=tp-ta;
  document.getElementById('budget-summary').innerHTML=`
    <div class="budget-stat"><div class="bs-label">Toplam Bütçe</div><div class="bs-val">₺${tp.toLocaleString('tr-TR')}</div><div class="bs-sub">Başlangıç sermayesi</div></div>
    <div class="budget-stat"><div class="bs-label">Harcanan</div><div class="bs-val" style="color:var(--amber)">₺${ta.toLocaleString('tr-TR')}</div><div class="bs-sub">%${Math.round(ta/tp*100)} kullanıldı</div></div>
    <div class="budget-stat"><div class="bs-label">Kalan</div><div class="bs-val" style="color:var(--green)">₺${rem.toLocaleString('tr-TR')}</div><div class="bs-sub">Kullanılabilir bütçe</div></div>
  `;
  const tbody=document.getElementById('budget-tbody');
  tbody.innerHTML='';
  budget.forEach(b=>{
    const diff=b.actual-b.planned;
    const diffStr=diff===0?'—':diff>0?`+₺${Math.abs(diff).toLocaleString('tr-TR')}`:`-₺${Math.abs(diff).toLocaleString('tr-TR')}`;
    const diffColor=diff>0?'color:var(--red)':diff<0?'color:var(--green)':'color:var(--text3)';
    const tc=tagCls[b.cat]||'tag-blue';
    const statCls=b.actual===0?'sp-gray':b.actual>b.planned?'sp-red':'sp-green';
    const statTxt=b.actual===0?'Bekliyor':b.actual>b.planned?'Aşıldı':'Normal';
    tbody.innerHTML+=`<tr>
      <td style="font-weight:500">${b.item}</td>
      <td><span class="tag ${tc}">${b.cat}</span></td>
      <td>₺${b.planned.toLocaleString('tr-TR')}</td>
      <td>${b.actual>0?'₺'+b.actual.toLocaleString('tr-TR'):'<span style="color:var(--text3)">—</span>'}</td>
      <td style="${diffColor};font-weight:600">${diffStr}</td>
      <td><span class="status-pill ${statCls}"><span class="dot"></span>${statTxt}</span></td>
    </tr>`;
  });
}

