    const div=document.createElement('div');
    div.className='col';
    div.innerHTML=`<div class="col-head">
      <span class="col-title" style="color:${c.color}">${c.label}</span>
      <span class="col-count">${ct.length}</span>
    </div>`;
    ct.forEach(t=>{
      const tc=tagCls[t.tag]||'tag-green';
      const ac=avCls[t.owner]||'av-green';
      div.innerHTML+=`<div class="task">
        <div class="task-title">${t.title}</div>
        <div class="task-footer">
          <span class="tag ${tc}">${t.tag}</span>
          <div class="av-xs ${ac}">${t.owner}</div>
        </div>
      </div>`;
    });
    div.innerHTML+=`<button class="add-task-btn" onclick="openModal()">+ Görev ekle</button>`;
    board.appendChild(div);
  });
}

function renderTimeline(){
  const container = document.getElementById('gantt-container');
  const chartStart = new Date('2025-05-01');
  const chartEnd = new Date('2025-07-05');
  const today = new Date(); 
  const dayWidth = 25;
  const totalDays = Math.ceil((chartEnd - chartStart) / (1000 * 60 * 60 * 24));
  let html = `<div class="gantt-grid" style="width: ${totalDays * dayWidth + 220}px">`;
  html += `<div class="gantt-header-dates"><div style="width:220px; flex-shrink:0; position:sticky; left:0; background:var(--bg3); z-index:11; border-right:1px solid var(--border)"></div>`;
  let d = new Date(chartStart);
  for(let i=0; i<=totalDays; i++) {
      html += `<div class="gantt-date" style="width:${dayWidth}px; flex-shrink:0">${d.getDate()}/${d.getMonth()+1}</div>`;
      d.setDate(d.getDate() + 1);
  }
  html += `</div><div class="gantt-body">`;
  const todayOffset = Math.ceil((today - chartStart) / (1000 * 60 * 60 * 24)) * dayWidth;
  if(todayOffset > 0 && todayOffset < totalDays * dayWidth) {
      html += `<div class="gantt-today-line" style="left: ${220 + todayOffset}px">
                  <div class="gantt-today-label">Bugün</div>
               </div>`;
  }
  const sortedTasks = [...tasks].sort((a,b) => a.owner.localeCompare(b.owner));
  sortedTasks.forEach(t => {
    const tStart = new Date(t.start);
    const tEnd = new Date(t.end);
    const startOffset = Math.max(0, Math.ceil((tStart - chartStart) / (1000 * 60 * 60 * 24))) * dayWidth;
    const durationDays = Math.max(1, Math.ceil((tEnd - tStart) / (1000 * 60 * 60 * 24)));
    const width = durationDays * dayWidth;
    const criticalClass = t.isCritical ? 'gantt-critical' : '';
    const barColor = t.isCritical ? 'var(--red)' : 'var(--blue)';
    html += `
      <div class="gantt-row ${criticalClass}">
        <div class="gantt-label">
            <span class="av-xs ${avCls[t.owner]||'av-green'}">${t.owner}</span>
            <span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis" title="${t.title}">${t.title}</span>
        </div>
        <div class="gantt-bars-container">
            <div class="gantt-bar-wrap" style="left: ${startOffset}px; width: ${width}px;" title="%${t.progress} Tamamlandı">
                <div class="gantt-bar-progress" style="width: ${t.progress}%; background: ${barColor}"></div>
                <div class="gantt-bar-text">%${t.progress}</div>
            </div>
        </div>
      </div>`;
  });
  html += `</div></div>`;
  container.innerHTML = html;
}

